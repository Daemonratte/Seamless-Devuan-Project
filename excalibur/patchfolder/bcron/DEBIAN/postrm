if [ "$1" = "remove" ] && [ -x "/etc/init.d/bcron-spool" ] ; then
	chmod -x "/etc/init.d/bcron-spool" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d bcron-spool remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installinit/13.22
