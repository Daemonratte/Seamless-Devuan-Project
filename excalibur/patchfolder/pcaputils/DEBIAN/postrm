#!/bin/sh -e

if [ "$1" = "purge" ]; then
	rm -rf /etc/pcapdump /var/run/pcapdump
fi

# Automatically added by dh_installinit/13.20
if [ "$1" = "remove" ] && [ -x "/etc/init.d/pcapdump" ] ; then
	chmod -x "/etc/init.d/pcapdump" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d pcapdump remove >/dev/null
fi
# End automatically added section

