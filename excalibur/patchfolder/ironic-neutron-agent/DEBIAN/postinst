#!/bin/sh

set -e

if [ "${1}" = "configure" ] || [ "${1}" = "reconfigure" ] ; then
	if ! [ -e /etc/neutron/plugins/ml2/ironic_neutron_agent.ini ] ; then
		cp /usr/share/ironic-neutron-agent/ironic_neutron_agent.ini /etc/neutron/plugins/ml2/ironic_neutron_agent.ini
	fi
fi

# Automatically added by dh_installinit/13.24.1
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -z "$DPKG_ROOT" ] && [ -x "/etc/init.d/ironic-neutron-agent" ]; then
		update-rc.d ironic-neutron-agent defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d ironic-neutron-agent $_dh_action || true
	fi
fi
# End automatically added section


exit 0
