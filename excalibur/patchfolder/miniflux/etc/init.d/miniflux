#!/bin/sh

### BEGIN INIT INFO
# Provides:          miniflux
# Required-Start:    $remote_fs $network
# Required-Stop:     $remote_fs $network
# Should-Start:      postgresql
# Should-Stop:       postgresql
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: minimalist and opinionated feed reader
# Description:       Miniflux is a minimalist and opinionated feed reader:
#                      - Written in Go (Golang)
#                      - Works only with PostgreSQL
#                      - Doesn't use any ORM
#                      - Doesn't use any complicated framework
#                      - Use only modern vanilla Javascript (ES6 and Fetch API)
#                      - Single binary compiled statically without dependency
#                      - The number of features is voluntarily limited
#                    It's simple, fast, lightweight and super easy to install.
### END INIT INFO

set -e

PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin

DAEMON=/usr/bin/miniflux
NAME=miniflux
DESC="feed reader"
PIDFILE=/var/run/miniflux.pid
DAEMON_OPTS="-c /etc/miniflux/miniflux.conf"
DAEMON_USER=miniflux
DAEMON_GROUP=miniflux

. /lib/lsb/init-functions

if ! getent passwd | grep -q "^$DAEMON_USER:"; then
        echo "Server user does not exist. Aborting" >&2
        exit 1
fi
if ! getent group | grep -q "^$DAEMON_GROUP:" ; then
        echo "Server group does not exist. Aborting" >&2
        exit 1
fi

do_start() {
        start-stop-daemon --start --quiet --pidfile $PIDFILE --make-pidfile \
                --background --chuid $DAEMONUSER --exec $DAEMON -- $DAEMON_OPTS
}

do_stop() {
        start-stop-daemon --stop --quiet --retry=TERM/30/KILL/5 --pidfile $PIDFILE \
                --user $DAEMONUSER --exec $DAEMON
}

case "$1" in
start)
        log_daemon_msg "Starting $DESC" "$NAME"
        do_start
        case "$?" in
        0) log_end_msg 0 ;;
        1)
                log_progress_msg "already started"
                log_end_msg 0
                ;;
        *) log_end_msg $? ;;
        esac
        ;;
stop)
        log_daemon_msg "Stopping $DESC" "$NAME"
        do_stop
        case "$?" in
        0) log_end_msg 0 ;;
        1)
                log_progress_msg "already stopped"
                log_end_msg 0
                ;;
        *) log_end_msg $? ;;
        esac
        ;;
restart | force-reload)
        $0 stop
        $0 start
        ;;
status)
        status_of_proc -p $PIDFILE $DAEMON $NAME && exit 0 || exit $?
        ;;
*)
        echo "Usage: /etc/init.d/$NAME {start|stop|restart|reload|force-reload|status}" >&2
        exit 3
        ;;
esac

exit 0
