#!/bin/sh

set -e

case "$1" in
  install|upgrade)
    DOCDIR=/usr/share/doc/zookeeperd

    if [ -L $DOCDIR ]; then
      rm $DOCDIR
    fi
  ;;
esac

# Automatically added by dh_installinit/13.24.2
if [ "$1" = "install" ] && [ -n "$2" ] && [ -e "/etc/init.d/zookeeper" ] ; then
	chmod +x "/etc/init.d/zookeeper" >/dev/null || true
fi
# End automatically added section


exit 0
