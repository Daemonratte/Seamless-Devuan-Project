#!/bin/sh

set -e

# Automatically added by dh_installinit/13.14.1
if [ "$1" = "remove" ] && [ -x "/etc/init.d/pommed" ] ; then
	chmod -x "/etc/init.d/pommed" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d pommed remove >/dev/null
fi
# End automatically added section


if [ -x /etc/init.d/dbus ]; then
    invoke-rc.d dbus force-reload || true
fi
