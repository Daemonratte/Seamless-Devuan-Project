#!/bin/sh

set -e

if [ "$1" = purge ]; then
    rm -rf /etc/corosync/qnetd/nssdb
fi

# Automatically added by dh_installinit/13.16
if [ "$1" = "remove" ] && [ -x "/etc/init.d/corosync-qnetd" ] ; then
	chmod -x "/etc/init.d/corosync-qnetd" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d corosync-qnetd remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installdeb/13.16
dpkg-maintscript-helper rm_conffile /etc/default/corosync-qnetd 3.0.0-1\~ -- "$@"
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'corosync-qnetd.service' >/dev/null || true
	fi
fi
# End automatically added section

