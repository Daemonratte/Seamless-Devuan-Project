#!/bin/sh

set -e

# Automatically added by dh_installinit/13.16
if [ "$1" = "remove" ] && [ -x "/etc/init.d/a2d" ] ; then
	chmod -x "/etc/init.d/a2d" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d a2d remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'a2d.service' 'a2d.timer' >/dev/null || true
	fi
fi
# End automatically added section


# Check if nginx is installed
if [ -x "$(command -v nginx)" ]; then
    # Check if nginx service is active
    if systemctl is-active --quiet nginx; then
        # Reload nginx
        deb-systemd-invoke reload nginx
    fi
fi

exit 0
