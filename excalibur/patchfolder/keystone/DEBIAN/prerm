#!/bin/sh

set -e

. /usr/share/debconf/confmodule

db_get keystone/configure_db
if [ "$RET" = "true" ]; then
    . /usr/share/dbconfig-common/dpkg/prerm
    dbc_go keystone $@
fi

# Automatically added by dh_installinit/13.24.2
if [ -z "$DPKG_ROOT" ] && [ "$1" = remove ] && [ -x "/etc/init.d/keystone" ] ; then
	invoke-rc.d keystone stop || true
fi
# End automatically added section


exit 0
