	if [ -z "$DPKG_ROOT" ] && [ -x "/usr/bin/deb-systemd-helper" ] ; then
		deb-systemd-helper --user purge 'filter-chain.service' 'pipewire.service' 'pipewire.socket' >/dev/null || true
	fi
fi
