[Unit]
Description=OpenStack Ceilometer Agent IPMI (ceilometer-agent-ipmi)
After=mongodb.service postgresql.service mysql.service keystone.service rabbitmq-server.service ntp.service network-online.target local-fs.target remote-fs.target 
Wants=mongodb.service postgresql.service mysql.service keystone.service rabbitmq-server.service ntp.service network-online.target 

Documentation=man:ceilometer-polling(1)

[Service]
User=ceilometer
Group=ceilometer
Type=simple
WorkingDirectory=~
RuntimeDirectory=ceilometer lock/ceilometer
CacheDirectory=ceilometer
ExecStart=/etc/init.d/ceilometer-polling systemd-start
Restart=on-failure
LimitNOFILE=65535
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
