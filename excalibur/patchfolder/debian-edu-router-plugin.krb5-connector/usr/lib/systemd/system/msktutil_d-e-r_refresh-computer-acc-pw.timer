[Unit]
Description=Periodically refreshes the password of computer accounts maintained by D-E-R-P.K-C
Requires=msktutil_d-e-r_refresh-computer-acc-pw.service

[Timer]
Unit=msktutil_d-e-r_refresh-computer-acc-pw.service
OnCalendar=*-*-* 05:00:00

[Install]
WantedBy=multi-user.target
