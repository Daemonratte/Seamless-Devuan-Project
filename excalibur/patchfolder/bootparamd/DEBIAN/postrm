#!/bin/sh
set -e
# Automatically added by dh_installinit/13.20
if [ "$1" = "remove" ] && [ -x "/etc/init.d/bootparamd" ] ; then
	chmod -x "/etc/init.d/bootparamd" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d bootparamd remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_systemd_enable/13.20
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'bootparamd.service' >/dev/null || true
	fi
fi
# End automatically added section
