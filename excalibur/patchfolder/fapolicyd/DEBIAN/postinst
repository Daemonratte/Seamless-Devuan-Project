#!/bin/sh
set -e

# add fapolicyd user/group if needed.
if ! getent group fapolicyd >/dev/null; then
	addgroup --system fapolicyd
fi
if ! getent passwd fapolicyd >/dev/null; then
	mkdir --mode=0755 -p "${DPKG_ROOT:-/}run/fapolicyd"
	adduser --system --quiet --ingroup fapolicyd \
		--home /run/fapolicyd/ --no-create-home \
		fapolicyd
	mkdir --mode=2755 -p "${DPKG_ROOT:-/}var/lib/fapolicyd"
	chown fapolicyd:fapolicyd "${DPKG_ROOT:-/}var/lib/fapolicyd"
fi

# Automatically added by dh_installtmpfiles/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -x "$(command -v systemd-tmpfiles)" ]; then
		systemd-tmpfiles ${DPKG_ROOT:+--root="$DPKG_ROOT"} --create fapolicyd.conf || true
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'fapolicyd.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'fapolicyd.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'fapolicyd.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'fapolicyd.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'fapolicyd.service' >/dev/null || true
fi
# End automatically added section

