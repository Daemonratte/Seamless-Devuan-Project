#!/bin/sh

set -e

action="$1"
version="$2"

if [ "$action" = upgrade ]
then
  if [ -L /usr/share/doc/snmpd ]; then
    rm -f /usr/share/doc/snmpd
  fi
fi

# Automatically added by dh_installinit/13.24.2
if [ "$1" = "install" ] && [ -n "$2" ] && [ -e "/etc/init.d/snmpd" ] ; then
	chmod +x "/etc/init.d/snmpd" >/dev/null || true
fi
# End automatically added section


exit 0
