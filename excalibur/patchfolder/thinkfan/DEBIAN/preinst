#!/bin/sh
# preinst script for thinkfan
#
# see: dh_installdeb(1)

set -e

case "$1" in
    upgrade)
        if [ -f /etc/thinkfan.yaml ]; then
            if [ "$(md5sum /etc/thinkfan.yaml)" = "de5d2b3154eb00014f445a001f6256b0  /etc/thinkfan.yaml" ]; then
                # Delete faulty config on upgrade
                rm /etc/thinkfan.yaml
            else
                # Preserve user-modified file
                mv /etc/thinkfan.yaml /etc/thinkfan.yaml.sav.1.2.1-3.1
            fi
        fi
    ;;

    install|abort-upgrade)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

# Automatically added by dh_installdeb/13.16
dpkg-maintscript-helper rm_conffile /etc/thinkfan.conf 1.2.1-1\~ thinkfan -- "$@"
dpkg-maintscript-helper rm_conffile /etc/systemd/system/thinkfan.service.d/override.conf 1.2.1-2\~ thinkfan -- "$@"
dpkg-maintscript-helper rm_conffile /etc/thinkfan.yaml 1.2.1-3.1\~ thinkfan -- "$@"
# End automatically added section
# Automatically added by dh_installinit/13.16
if [ "$1" = "install" ] && [ -n "$2" ] && [ -e "/etc/init.d/thinkfan" ] ; then
	chmod +x "/etc/init.d/thinkfan" >/dev/null || true
fi
# End automatically added section


exit 0
