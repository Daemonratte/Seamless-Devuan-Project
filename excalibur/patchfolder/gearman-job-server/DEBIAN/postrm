#!/bin/sh

set -e

GROUP="gearman"
USER="gearman"
LOGDIR="/var/log/gearman-job-server"

# shamelessly copied from debian mysql-server package...
#
# - Remove the gearman user only after all his owned files are purged.
#   
if [ "$1" = "purge" ]; then
  # we remove the mysql user only after all his owned files are purged
  rm -rf $LOGDIR
  rm -rf /var/run/gearman
	rm -rf /var/lib/gearman

  deluser --system --remove-home $USER || true
  delgroup --system --only-if-empty $GROUP || true
fi

# Automatically added by dh_installinit/13.24.2
if [ "$1" = "remove" ] && [ -x "/etc/init.d/gearman-job-server" ] ; then
	chmod -x "/etc/init.d/gearman-job-server" >/dev/null || true
fi
if [ -z "$DPKG_ROOT" ] && [ "$1" = "purge" ] ; then
	update-rc.d gearman-job-server remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_systemd_enable/13.24.2
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'gearman-job-server.service' >/dev/null || true
	fi
fi
# End automatically added section

