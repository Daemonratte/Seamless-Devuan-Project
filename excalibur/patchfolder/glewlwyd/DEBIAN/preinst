#!/bin/sh
set -e

if [ "$1" = "configure" ]; then
	echo "Stop Glewlwyd service"
	invoke-rc.d glewlwyd stop || true
fi
# Automatically added by dh_installinit/13.24.2
if [ "$1" = "install" ] && [ -n "$2" ] && [ -e "/etc/init.d/glewlwyd" ] ; then
	chmod +x "/etc/init.d/glewlwyd" >/dev/null || true
fi
# End automatically added section

