#!/bin/sh

set -e

case "$1" in
  purge)
    userdel miredo-server >/dev/null 2>&1 || true
  ;;
esac

# Automatically added by dh_installinit/13.16
if [ "$1" = "remove" ] && [ -x "/etc/init.d/miredo-server" ] ; then
	chmod -x "/etc/init.d/miredo-server" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d miredo-server remove >/dev/null
fi
# End automatically added section

