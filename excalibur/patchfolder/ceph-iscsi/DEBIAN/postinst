	if [ -z "${DPKG_ROOT:-}" ] && [ -x "/etc/init.d/rbd-target-api" ]; then
		update-rc.d rbd-target-api defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d --skip-systemd-native rbd-target-api $_dh_action || exit 1
	fi
fi
