#!/bin/sh

set -e

if [ "${1}" = "purge" ] ; then
	[ -d /etc/blazar ] && rmdir --ignore-fail-on-non-empty /etc/blazar
	rm -rf /var/log/blazar/blazar-manager.*
	[ -d /var/log/blazar ] && rmdir --ignore-fail-on-non-empty /var/log/blazar
fi

# Automatically added by dh_installinit/13.24.2
if [ "$1" = "remove" ] && [ -x "/etc/init.d/blazar-manager" ] ; then
	chmod -x "/etc/init.d/blazar-manager" >/dev/null || true
fi
if [ -z "$DPKG_ROOT" ] && [ "$1" = "purge" ] ; then
	update-rc.d blazar-manager remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'blazar-manager.service' >/dev/null || true
	fi
fi
# End automatically added section


exit 0
