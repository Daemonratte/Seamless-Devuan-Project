	if [ -z "$DPKG_ROOT" ] && [ -x "/etc/init.d/courierfilter" ]; then
		update-rc.d courierfilter defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d --skip-systemd-native courierfilter $_dh_action || exit 1
	fi
fi
# End automatically added section
