#!/bin/sh 

set -e

if [ "$1" = "disappear" -o "$1" = "remove" ]
then
	if [ ! -z `command -v update-inetd` ]
    then
        update-inetd --disable ftp
    fi
fi

if [ "$1" = "purge" ]
then
	# remove ucf hashes on purge
	if [ -x "/usr/bin/ucf" ]
	then
		ucf --purge /etc/proftpd/proftpd.conf
		ucf --purge /etc/proftpd/modules.conf
		ucf --purge /etc/proftpd/tls.conf
		ucf --purge /etc/proftpd/sql.conf
		ucf --purge /etc/proftpd/ldap.conf
		ucf --purge /etc/proftpd/virtuals.conf
		ucf --purge /etc/proftpd/sftp.conf
		ucf --purge /etc/proftpd/geoip.conf
		ucf --purge /etc/proftpd/snmp.conf
	fi
    rm -rf /etc/proftpd 
    rm -rf /var/log/proftpd
    rm -f /etc/logrotate.d/proftpd-core
    rm -f /srv/ftp/welcome.msg
    rmdir --ignore-fail-on-non-empty /srv/ftp
    userdel --remove --force proftpd || true
    userdel ftp || true
fi

# Automatically added by dh_installinit/13.24.2
if [ "$1" = "remove" ] && [ -x "/etc/init.d/proftpd" ] ; then
	chmod -x "/etc/init.d/proftpd" >/dev/null || true
fi
if [ -z "$DPKG_ROOT" ] && [ "$1" = "purge" ] ; then
	update-rc.d proftpd remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'proftpd.service' >/dev/null || true
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'proftpd.socket' >/dev/null || true
	fi
fi
# End automatically added section


