#!/bin/sh

set -e

# Automatically added by dh_installinit/13.24.1
if [ "$1" = "remove" ] && [ -x "/etc/init.d/radvd" ] ; then
	chmod -x "/etc/init.d/radvd" >/dev/null || true
fi
if [ -z "$DPKG_ROOT" ] && [ "$1" = "purge" ] ; then
	update-rc.d radvd remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_systemd_enable/13.24.1
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'radvd.service' >/dev/null || true
	fi
fi
# End automatically added section


if [ "$1" = purge ]; then
  if dpkg-statoverride --list /var/run/radvd >/dev/null; then
    dpkg-statoverride --remove /var/run/radvd
  fi
fi
