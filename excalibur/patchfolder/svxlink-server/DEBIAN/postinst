#!/bin/sh
# postinst script for svxlink
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <postinst> `configure' <most-recently-configured-version>
#        * <old-postinst> `abort-upgrade' <new version>
#        * <conflictor's-postinst> `abort-remove' `in-favour' <package>
#          <new-version>
#        * <postinst> `abort-remove'
#        * <deconfigured's-postinst> `abort-deconfigure' `in-favour'
#          <failed-install-package> <version> `removing'
#          <conflicting-package> <version>
# for details, see http://www.debian.org/doc/debian-policy/ or
# the debian-policy package


case "$1" in
    configure) 
    
    # Sane defaults:
    
    [ -z "$SERVER_HOME" ] && SERVER_HOME=/usr/bin
    [ -z "$SERVER_USER" ] && SERVER_USER=svxlink
    [ -z "$SERVER_GROUP" ] && SERVER_GROUP=daemon
    
#    chown $SERVER_USER:$SERVER_GROUP $SERVER_HOME/svxlink
    chown $SERVER_USER:$SERVER_GROUP /var/spool/svxlink/voice_mail/
    chown $SERVER_USER:$SERVER_GROUP /var/spool/svxlink/qso_recorder/
    chown $SERVER_USER:$SERVER_GROUP /var/spool/svxlink/propagation_monitor/
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

# Automatically added by dh_installinit/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -x "/etc/init.d/svxlink" ]; then
		update-rc.d svxlink defaults-disabled >/dev/null || exit 1
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'svxlink.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'svxlink.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'svxlink.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'svxlink.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'svxlink.service' >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'svxlink.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'svxlink.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'svxlink.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'svxlink.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'svxlink.service' >/dev/null || true
fi
# End automatically added section


exit 0


