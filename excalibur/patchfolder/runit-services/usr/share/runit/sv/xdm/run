DEFAULT_DISPLAY_MANAGER=$(cat /etc/X11/default-display-manager)
if [ $DEFAULT_DISPLAY_MANAGER != /usr/bin/xdm ]; then
	exit 161
fi

exec 1>&2

exec /usr/bin/xdm -nodaemon
