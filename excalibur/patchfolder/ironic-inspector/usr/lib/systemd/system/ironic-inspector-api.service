[Unit]
Description=OpenStack Ironic Introspection Service API (ironic-inspector-api)
After=postgresql.service mysql.service keystone.service ntp.service rabbitmq-server.service network-online.target local-fs.target remote-fs.target 
Wants=postgresql.service mysql.service keystone.service ntp.service rabbitmq-server.service network-online.target 

Documentation=man:ironic-inspector-api(1)

[Service]
User=ironic-inspector
Group=ironic-inspector
Type=simple
WorkingDirectory=~
RuntimeDirectory=ironic-inspector lock/ironic-inspector
CacheDirectory=ironic-inspector
ExecStart=/etc/init.d/ironic-inspector-api systemd-start
Restart=on-failure
LimitNOFILE=65535
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
