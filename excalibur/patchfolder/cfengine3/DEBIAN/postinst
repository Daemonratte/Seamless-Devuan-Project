# Automatically added by dh_systemd_start/13.24.1
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -d /run/systemd/system ]; then
		systemctl --system daemon-reload >/dev/null || true
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		deb-systemd-invoke $_dh_action 'cf-apache.service' 'cf-execd.service' 'cf-hub.service' 'cf-monitord.service' 'cf-postgres.service' 'cf-reactor.service' 'cf-serverd.service' 'cfengine3.service' >/dev/null || true
	fi
