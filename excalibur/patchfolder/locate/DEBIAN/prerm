#!/bin/sh

set -e

if [ "$1" != "upgrade" ]; then
  update-alternatives --remove locate /usr/bin/locate.findutils
fi


# Automatically added by dh_installsystemd/13.16
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	deb-systemd-invoke stop 'locate.service' 'locate.timer' >/dev/null || true
fi
# End automatically added section

