#!/usr/bin/env /lib/runit/invoke-run
#Copyright: 2022 Lorenzo Puliti <plorenzo@disroot.org>
#License: CC0-1.0

[ -f /etc/default/mysql ] &&  . /etc/default/mysql
export HOME=/etc/mysql/
[ ! -r /etc/mysql/my.cnf ] && echo  "WARNING: /etc/mysql/my.cnf cannot be read. See README.Debian.gz"

test -e /var/run/mysqld || install -m 755 -o mysql -g root -d /var/run/mysqld
exec 2>&1

exec ${XCHPST:-chpst -u mysql}  /usr/sbin/mysqld --skip-log-error
