#!/bin/sh -e
# postinst

USERNAME="Debian-console-log"

[ -n "$CONLOGDEBUG" ] && set -x

# Add user
if [ "$1" = "configure" ]; then
    echo >&2 'Adding system user'
    adduser --system --group --home /nonexistent \
	    --no-create-home --disabled-login --force-badname $USERNAME
    adduser $USERNAME adm
fi
    
# Automatically added by dh_installinit/13.3.1
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -x "/etc/init.d/console-log" ]; then
		update-rc.d console-log defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d console-log $_dh_action || exit 1
	fi
fi
# End automatically added section


# end of file
