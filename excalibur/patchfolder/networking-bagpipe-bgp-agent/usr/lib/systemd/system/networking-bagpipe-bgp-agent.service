[Unit]
Description=OpenStack Neutron Bagpipe BGP Agent (networking-bagpipe-bgp-agent)
After=mysql.service postgresql.service rabbitmq-server.service keystone.service openvswitch-switch.service neutron-server.service network-online.target local-fs.target remote-fs.target 
Wants=mysql.service postgresql.service rabbitmq-server.service keystone.service openvswitch-switch.service neutron-server.service network-online.target 

Documentation=man:networking-bagpipe-bgp-agent(1)

[Service]
User=neutron
Group=neutron
Type=simple
WorkingDirectory=~
RuntimeDirectory=neutron lock/neutron
CacheDirectory=neutron
ExecStart=/etc/init.d/networking-bagpipe-bgp-agent systemd-start
Restart=on-failure
LimitNOFILE=65535
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
