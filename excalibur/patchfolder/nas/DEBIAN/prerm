#!/bin/sh -e

if [ \( "$1" = "upgrade" -o "$1" = "remove" \) -a -L /usr/doc/nas ]; then
 	rm -f /usr/doc/nas
fi

# Automatically added by dh_installinit/13.15.3
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = remove ] && [ -x "/etc/init.d/nas" ] ; then
	invoke-rc.d --skip-systemd-native nas stop || exit 1
fi
# End automatically added section

