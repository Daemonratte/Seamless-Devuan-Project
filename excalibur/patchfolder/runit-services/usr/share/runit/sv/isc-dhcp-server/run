exec 2>&1

[ -n "$INTERFACESv4" ] || {
  echo "invoke-run: no IPv4 interfaces specified for ${PWD##*/}"
  exit 162
}

leases="/var/lib/dhcp/dhcpd.leases"
[ -e "$leases" ] || touch "$leases"

/usr/sbin/dhcpd -4 -f -d -t $INTERFACESv4 || exit 162
/usr/sbin/dhcpd -4 -f -d -T $INTERFACESv4 || exit 162

exec /usr/sbin/dhcpd -4 -f -d $INTERFACESv4
