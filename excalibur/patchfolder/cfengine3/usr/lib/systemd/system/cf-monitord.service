[Unit]
Description=CFEngine Monitor Daemon
After=syslog.target
ConditionPathExists=/usr/bin/cf-monitord
ConditionPathExists=/var/lib/cfengine3/inputs/promises.cf
PartOf=cfengine3.service

[Service]
Type=simple
ExecStart=/usr/bin/cf-monitord --no-fork
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
