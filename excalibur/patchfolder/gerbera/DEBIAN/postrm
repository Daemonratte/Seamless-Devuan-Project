#!/bin/sh
set -e

if [ "$1" = "purge" ] ; then
    rm -rf /var/lib/gerbera
    rm -rf /var/log/gerbera.log* /var/run/gerbera.pid
    dpkg-statoverride --remove /etc/gerbera/config.xml
    dpkg-statoverride --remove /var/lib/gerbera
    deluser --system gerbera || true
    delgroup --system gerbera || true
fi

# Automatically added by dh_installinit/13.24.1
if [ "$1" = "remove" ] && [ -x "/etc/init.d/gerbera" ] ; then
	chmod -x "/etc/init.d/gerbera" >/dev/null || true
fi
if [ -z "$DPKG_ROOT" ] && [ "$1" = "purge" ] ; then
	update-rc.d gerbera remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.1
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.1
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'gerbera.service' >/dev/null || true
	fi
fi
# End automatically added section

