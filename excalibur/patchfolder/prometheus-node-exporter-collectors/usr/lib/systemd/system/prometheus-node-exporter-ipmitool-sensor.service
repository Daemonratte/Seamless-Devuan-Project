[Unit]
Description=Collect ipmitool sensor metrics for prometheus-node-exporter
After=systemd-modules-load.service

[Service]
Type=oneshot
Environment=LC_ALL=C
Environment=TMPDIR=/var/lib/prometheus/node-exporter
ExecStart=/bin/sh -o pipefail -c "/usr/bin/ipmitool sensor | /usr/share/prometheus-node-exporter-collectors/ipmitool | sponge /var/lib/prometheus/node-exporter/ipmitool_sensor.prom"
