#!/bin/sh
# preinst script for slurmctld
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <new-preinst> `install'
#        * <new-preinst> `install' <old-version>
#        * <new-preinst> `upgrade' <old-version>
#        * <old-preinst> `abort-upgrade' <new-version>
#
# for details, see http://www.debian.org/doc/debian-policy/ or
# the debian-policy package

case "$1" in
    install)
      # Copying relevant changes from the old default file
      if [ -e /etc/default/slurm-llnl -a ! -e /etc/default/slurmctld ] ; then
        if grep "SLURMCTLD_OPTIONS" /etc/default/slurm-llnl | grep -qv '^ *#' 2>/dev/null ; then
           grep "SLURMCTLD_OPTIONS" /etc/default/slurm-llnl >> \
               /etc/default/slurmctld 2>/dev/null
        fi
      fi
    ;;

    upgrade)
    ;;

    abort-upgrade)
    ;;

    *)
        echo "preinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

# Automatically added by dh_installinit/13.24.2
if [ "$1" = "install" ] && [ -n "$2" ] && [ -e "/etc/init.d/slurmctld" ] ; then
	chmod +x "/etc/init.d/slurmctld" >/dev/null || true
fi
# End automatically added section


exit 0
