#!/bin/sh
set -e

W2L="welcome2l"

# Remove /etc/issue.welcome2l
if  [ "$1" = remove ] || [ "$1" = purge ]; then
  rm -f /etc/issue."$W2L"
fi

# Automatically added by dh_installinit/13.11.9
if [ "$1" = "remove" ] && [ -x "/etc/init.d/welcome2l" ] ; then
	chmod -x "/etc/init.d/welcome2l" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d welcome2l remove >/dev/null
fi
# End automatically added section

