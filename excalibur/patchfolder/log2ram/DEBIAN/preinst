#!/bin/bash

set -e

result=$(deb-systemd-invoke is-active log2ram.service) || true
if [[ "$result" == "active" ]]; then
    deb-systemd-invoke stop log2ram.service
fi

result=$(deb-systemd-invoke is-active log2ram-daily.timer) || true
if [[ "$result" == "active" ]]; then
    deb-systemd-invoke stop log2ram-daily.timer
fi

rm -rf /var/hdd.log

# Automatically added by dh_installsystemd/13.24.1
if [ -z "$DPKG_ROOT" ] && [ "$1" = upgrade ] && [ -d /run/systemd/system ] ; then
	deb-systemd-invoke stop 'log2ram-daily.service' 'log2ram-daily.timer' 'log2ram.service' >/dev/null || true
fi
# End automatically added section


exit 0
