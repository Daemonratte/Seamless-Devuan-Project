#! /bin/sh
set -e

if [ "$1" = "purge" ] ; then
    # remove overrides
    DIRS="/var/spool/gammu/inbox /var/spool/gammu/outbox /var/spool/gammu/sent /var/spool/gammu/error"
    for dir in $DIRS ; do
        if dpkg-statoverride --list --quiet $dir >/dev/null ; then
            dpkg-statoverride --force-all --quiet --remove $dir
        fi
    done

    # delete user
    if getent passwd gammu >/dev/null; then
        if [ -x "$(command -v deluser)" ]; then
            deluser --quiet --system gammu > /dev/null || true
        else
            echo >&2 "not removing gammu system account because deluser command was not found"
        fi
    fi

    # delete group
    if getent group gammu >/dev/null; then
        if [ -x "$(command -v delgroup)" ]; then
            delgroup gammu > /dev/null || true
        else
            echo >&2 "not removing gammu system group because delgroup command was not found"
        fi
    fi
fi

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

# Automatically added by dh_installinit/13.20
if [ "$1" = "remove" ] && [ -x "/etc/init.d/gammu-smsd" ] ; then
	chmod -x "/etc/init.d/gammu-smsd" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d gammu-smsd remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.20
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.20
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'gammu-smsd.service' >/dev/null || true
	fi
fi
# End automatically added section


exit 0

