#!/bin/sh

set -e

NAME="ppp-gatekeeper"

case "$1" in
	remove)
		;;
	purge)
		rm -rf /var/log/ppp-gatekeeper
		;;
	failed-upgrade|abort-install|abort-upgrade|disappear|upgrade)
		;;
	*)
		echo "postrm called with unknown argument '$@'"
		exit 1
		;;
esac

# Automatically added by dh_installinit/13.3.1
if [ "$1" = "purge" ] ; then
	update-rc.d ppp-gatekeeper remove >/dev/null
fi
# End automatically added section


exit 0
