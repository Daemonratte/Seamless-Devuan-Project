if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'ntfy-client.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'ntfy-client.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'ntfy-client.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'ntfy-client.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'ntfy-client.service' >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'ntfy.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'ntfy.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'ntfy.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'ntfy.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'ntfy.service' >/dev/null || true
fi
