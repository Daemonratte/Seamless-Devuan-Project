if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'cni-dhcp.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'cni-dhcp.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'cni-dhcp.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'cni-dhcp.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'cni-dhcp.service' >/dev/null || true
fi
# End automatically added section
