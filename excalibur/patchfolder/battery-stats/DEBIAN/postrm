#!/bin/sh

set -e

if [ "$1" = purge ]; then
	rm -f /var/log/battery-stats*
fi

# Automatically added by dh_installinit/13.12
if [ "$1" = "remove" ] && [ -x "/etc/init.d/battery-stats" ] ; then
	chmod -x "/etc/init.d/battery-stats" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d battery-stats remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.12
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.12
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'battery-stats.service' >/dev/null || true
	fi
fi
# End automatically added section

