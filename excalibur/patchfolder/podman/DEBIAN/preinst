#!/bin/sh

# podman 5.2.2+ds1-2 moved files to podman-docker, cf. #1083242
if [ -z "$(dpkg-query -f '${Version}' -W podman-docker 2> /dev/null)" ]; then
    dpkg-maintscript-helper rm_conffile /etc/profile.d/podman-docker.csh 5.2.2+ds1-2 -- "$@"
