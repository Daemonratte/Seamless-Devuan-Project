#!/bin/sh
# postrm script for yadifa
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <postrm> `remove'
#        * <postrm> `purge'
#        * <old-postrm> `upgrade' <new-version>
#        * <new-postrm> `failed-upgrade' <old-version>
#        * <new-postrm> `abort-install'
#        * <new-postrm> `abort-install' <old-version>
#        * <new-postrm> `abort-upgrade' <old-version>
#        * <disappearer's-postrm> `disappear' <overwriter>
#          <overwriter-version>
# for details, see http://www.debian.org/doc/debian-policy/ or
# the debian-policy package

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

# Automatically added by dh_installinit/13.24.1
if [ "$1" = "remove" ] && [ -x "/etc/init.d/yadifa" ] ; then
	chmod -x "/etc/init.d/yadifa" >/dev/null || true
fi
if [ -z "$DPKG_ROOT" ] && [ "$1" = "purge" ] ; then
	update-rc.d yadifa remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.1
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.1
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'yadifa.service' >/dev/null || true
	fi
fi
# End automatically added section


if [ "$1" = "purge" ]; then
	rm -f /etc/default/yadifa
	rm -f /var/lib/yadifa/yadifa-default.md5sum
	rmdir /var/lib/yadifa 2>/dev/null || true 

	dpkg-statoverride --remove /var/lib/yadifa/keys >/dev/null 2>/dev/null || true
	dpkg-statoverride --remove /var/lib/yadifa/primaries >/dev/null 2>/dev/null || true
	dpkg-statoverride --remove /var/lib/yadifa/secondaries >/dev/null 2>/dev/null || true
	dpkg-statoverride --remove /var/lib/yadifa/xfr >/dev/null 2>/dev/null || true
	dpkg-statoverride --remove /var/lib/yadifa >/dev/null 2>/dev/null || true
	dpkg-statoverride --remove /var/log/yadifa >/dev/null 2>/dev/null || true

	# delete yadifa daemon user, if it exists
	if getent passwd yadifa > /dev/null ; then
	    echo "Deleting yadifa user"
	    deluser  --quiet yadifa > /dev/null || true
	fi
fi

exit 0
