#!/bin/sh
# postinst script for thinkfan
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <postinst> `configure' <most-recently-configured-version>
#        * <old-postinst> `abort-upgrade' <new version>
#        * <conflictor's-postinst> `abort-remove' `in-favour' <package>
#          <new-version>
#        * <postinst> `abort-remove'
#        * <deconfigured's-postinst> `abort-deconfigure' `in-favour'
#          <failed-install-package> <version> `removing'
#          <conflicting-package> <version>
# for details, see https://www.debian.org/doc/debian-policy/ or
# the debian-policy package


case "$1" in
    configure)
        # Salvage backupped conffile
        if [ -e /etc/thinkfan.yaml.sav.1.2.1-3.1 ]; then
            mv /etc/thinkfan.yaml.sav.1.2.1-3.1 /etc/thinkfan.yaml
        fi

        if [ -x "/etc/init.d/thinkfan" ] && [ -z "$2" ]; then
            # Disable the service by default on new installations
            update-rc.d thinkfan defaults >/dev/null || true
            update-rc.d thinkfan disable >/dev/null || true
        fi
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

# Automatically added by dh_installdeb/13.16
dpkg-maintscript-helper rm_conffile /etc/thinkfan.conf 1.2.1-1\~ thinkfan -- "$@"
dpkg-maintscript-helper rm_conffile /etc/systemd/system/thinkfan.service.d/override.conf 1.2.1-2\~ thinkfan -- "$@"
dpkg-maintscript-helper rm_conffile /etc/thinkfan.yaml 1.2.1-3.1\~ thinkfan -- "$@"
# End automatically added section
# Automatically added by dh_installinit/13.16
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -z "${DPKG_ROOT:-}" ] && [ -x "/etc/init.d/thinkfan" ]; then
		update-rc.d thinkfan defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d --skip-systemd-native thinkfan $_dh_action || exit 1
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'thinkfan-sleep.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'thinkfan-sleep.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'thinkfan-sleep.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'thinkfan-sleep.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'thinkfan-sleep.service' >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'thinkfan-wakeup.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'thinkfan-wakeup.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'thinkfan-wakeup.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'thinkfan-wakeup.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'thinkfan-wakeup.service' >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'thinkfan.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'thinkfan.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'thinkfan.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'thinkfan.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'thinkfan.service' >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -d /run/systemd/system ]; then
		systemctl --system daemon-reload >/dev/null || true
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		deb-systemd-invoke $_dh_action 'thinkfan-sleep.service' 'thinkfan-wakeup.service' 'thinkfan.service' >/dev/null || true
	fi
fi
# End automatically added section


exit 0
