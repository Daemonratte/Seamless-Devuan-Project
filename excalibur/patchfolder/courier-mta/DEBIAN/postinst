		update-rc.d courier-msa defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d --skip-systemd-native courier-msa $_dh_action || exit 1
	fi
