#!/bin/sh

set -e

case "$1" in
  upgrade)
    version=$2
    if dpkg --compare-versions $version lt 0.1.0-3; then
      if [ -d /etc/alertmanager-irc-relay.yml ]; then
        rm -rfv /etc/alertmanager-irc-relay.yml
      fi
    fi
  ;;

  install|abort-upgrade)
    :
  ;;

  *)
    echo "preinst called with unknown argument \`$1'" >&2
    exit 1
  ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

# Automatically added by dh_installinit/13.24.1
if [ "$1" = "install" ] && [ -n "$2" ] && [ -e "/etc/init.d/alertmanager-irc-relay" ] ; then
	chmod +x "/etc/init.d/alertmanager-irc-relay" >/dev/null || true
fi
# End automatically added section


exit 0

