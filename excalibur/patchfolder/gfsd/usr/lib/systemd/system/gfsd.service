[Unit]
Description=Gfarm filesystem node daemon
Documentation=man:gfsd
After=network.target

[Service]
Type=forking
PIDFile=/var/run/gfsd.pid
User=root
Group=root
Environment=X509_USER_CERT=/etc/grid-security/gfsd/gfsdcert.pem
Environment=X509_USER_KEY=/etc/grid-security/gfsd/gfsdkey.pem
ExecStart=/usr/sbin/gfsd -v -P /var/run/gfsd.pid -f /etc/gfarm2.conf -h %H
OOMScoreAdjust=-1000
TimeoutSec=300

[Install]
WantedBy=multi-user.target
