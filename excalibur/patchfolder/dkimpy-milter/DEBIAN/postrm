#!/bin/sh
set -e
# Automatically added by dh_installinit/13.23
if [ "$1" = "remove" ] && [ -x "/etc/init.d/dkimpy-milter" ] ; then
	chmod -x "/etc/init.d/dkimpy-milter" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d dkimpy-milter remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installdeb/13.23
dpkg-maintscript-helper mv_conffile /etc/dkimpy-milter.conf /etc/dkimpy-milter/dkimpy-milter.conf 1.1.4-1 -- "$@"
# End automatically added section
# Automatically added by dh_installsystemd/13.23
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.23
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'dkimpy-milter.service' >/dev/null || true
	fi
fi
# End automatically added section
