#!/bin/sh

set -e

# Automatically added by dh_installinit/13.20
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -z "${DPKG_ROOT:-}" ] && [ -x "/etc/init.d/oddjobd" ]; then
		update-rc.d oddjobd defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d --skip-systemd-native oddjobd $_dh_action || exit 1
	fi
fi
# End automatically added section


if [ "$1" = triggered ]; then
    deb-systemd-invoke restart oddjobd.service
    exit 0
fi
