	if [ -z "$DPKG_ROOT" ] && [ -x "/etc/init.d/atop" ]; then
		update-rc.d atop defaults >/dev/null
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		invoke-rc.d --skip-systemd-native atop $_dh_action || exit 1
	fi
fi
