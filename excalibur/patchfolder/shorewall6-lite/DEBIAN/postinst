#!/bin/sh
set -e
# Automatically added by dh_installinit/13.16
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -x "/etc/init.d/shorewall6-lite" ]; then
		update-rc.d shorewall6-lite defaults-disabled >/dev/null || exit 1
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.16
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'shorewall6-lite.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'shorewall6-lite.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'shorewall6-lite.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'shorewall6-lite.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'shorewall6-lite.service' >/dev/null || true
fi
# End automatically added section
