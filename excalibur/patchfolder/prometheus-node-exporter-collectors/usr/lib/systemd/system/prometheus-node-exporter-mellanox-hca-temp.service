[Unit]
Description=Collect Mellanox HCA temperatures for prometheus-node-exporter
After=network-pre.target rdma-hw.target

[Service]
Type=oneshot
Environment=TMPDIR=/var/lib/prometheus/node-exporter
ExecStart=/bin/sh -o pipefail -c "/usr/share/prometheus-node-exporter-collectors/mellanox_hca_temp | sponge /var/lib/prometheus/node-exporter/mellanox_hca_temp.prom"
