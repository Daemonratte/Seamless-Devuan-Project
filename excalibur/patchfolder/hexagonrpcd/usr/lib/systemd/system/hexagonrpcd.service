[Unit]
Description=Hexagon DSP sensors daemon
Documentation=man:hexagonrpcd(1) file:///usr/share/doc/hexagonrpcd/README.Debian
ConditionKernelVersion=>=6.12
Conflicts=shutdown.target
After=multi-user.target
Before=shutdown.target

[Service]
Type=simple
NoNewPrivileges=yes
PrivateTmp=yes
DevicePolicy=closed
DeviceAllow=/dev/fastrpc-adsp
DeviceAllow=/dev/fastrpc-sdsp
DeviceAllow=/dev/fastrpc-cdsp
DeviceAllow=/dev/fastrpc-adsp-secure
DeviceAllow=/dev/fastrpc-sdsp-secure
DeviceAllow=/dev/fastrpc-cdsp-secure
ProtectSystem=strict
ProtectHome=read-only
ProtectControlGroups=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
PrivateNetwork=yes
RestrictAddressFamilies=none
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
MemoryDenyWriteExecute=yes
LockPersonality=yes
CapabilityBoundingSet=
ExecStart=/usr/bin/hexagonrpcd
User=fastrpc
Group=fastrpc

[Install]
WantedBy=default.target
