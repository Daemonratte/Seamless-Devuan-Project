#!/bin/sh

set -e

if [ "$1" = purge ]; then
    deluser --quiet --system lbcd > /dev/null || true
fi

# Automatically added by dh_installinit/13.11.8
if [ "$1" = "remove" ] && [ -x "/etc/init.d/lbcd" ] ; then
	chmod -x "/etc/init.d/lbcd" >/dev/null || true
fi
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = "purge" ] ; then
	update-rc.d lbcd remove >/dev/null
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.11.8
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'lbcd.service' 'lbcd.socket' >/dev/null || true
	fi
fi
# End automatically added section

